{
    "files.associations": {
        "*.yal": "yalok"
    },
    "editor.tabSize": 4,
    "editor.insertSpaces": true,
    "editor.detectIndentation": false,
    "C_Cpp.default.cppStandard": "c++17",
    "C_Cpp.default.intelliSenseMode": "gcc-x64",
    "cmake.configureOnOpen": true,
    "cmake.buildBeforeRun": true,
    "files.exclude": {
        "**/*.o": true,
        "build/": true,
        "**/.DS_Store": true
    },
    "search.exclude": {
        "build/": true,
        "**/*.o": true
    }
}
